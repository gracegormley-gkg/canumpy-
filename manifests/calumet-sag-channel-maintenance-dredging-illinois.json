        ]
      }
    },
    {
      "label": {
        "none": [
          "Notable Quotes"
        ]
      },
      "value": {
        "none": [
          "\"Opinions voiced by both the general public and the Illinois Environmental Protection Agency (IEPA) indicated that a positive barrier separating the dredged material from the ground water aquifer would be the only acceptable means of preventing ground water pollution.\" — Public and IEPA Concerns"
        ]
      }
    }
